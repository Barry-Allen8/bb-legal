{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "destination": "/pl/", "permanent": false },
    { "source": "/faq", "destination": "/pl/faq/", "permanent": true },
    { "source": "/services", "destination": "/pl/karta-pobytu-bydgoszcz/", "permanent": true },
    { "source": "/about", "destination": "/pl/o-nas/", "permanent": true },
    { "source": "/contact", "destination": "/pl/kontakt/", "permanent": true },
    { "source": "/kontakt", "destination": "/pl/kontakt/", "permanent": true },
    { "source": "/mos", "destination": "/pl/mos/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
